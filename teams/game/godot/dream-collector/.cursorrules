│   ├── CombatManager.gd  # Turn-based combat system
│   ├── DeckManager.gd    # Deck building, hand management
│   └── MainLobbyUI.gd    # Main lobby controller
├── ui/
│   ├── screens/          # 12 main screens
│   │   ├── MainLobby.tscn/gd         # Home hub
